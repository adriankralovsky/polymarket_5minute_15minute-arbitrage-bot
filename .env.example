# ─────────────────────────────────────────────────────────────────────────────
# BTC 5m/15m Arbitrage Bot — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Wallet (required) ─────────────────────────────────────────────────────────
# Your Polygon wallet private key (hex, with or without 0x prefix)
POLY_PRIVATE_KEY=your_private_key_hex

# Wallet type: main/eoa/0 = EOA (standard MetaMask-style), proxy/1/2 = Proxy wallet
POLY_WALLET_TYPE=main

# Required only when POLY_WALLET_TYPE=proxy/1/2 — the funding wallet address
# POLY_FUNDER=0xYOUR_MAIN_WALLET_ADDRESS

# ── Network ───────────────────────────────────────────────────────────────────
# Polygon Mainnet RPC — use Alchemy or Infura for reliability
POLY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Override the Polymarket exchange contract address (leave blank to use default)
# Default: 0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
POLYMARKET_EXCHANGE_ADDRESS=

# Override the Polymarket WebSocket URL (leave blank to use default)
# POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=btc_arbitrage

# ── Trading ───────────────────────────────────────────────────────────────────
# Set to 1 to place real orders. Leave at 0 for observation/dry-run mode.
ENABLE_TRADING=0

# USDC amount per leg. Each arb attempt spends 2x this value total.
DEFAULT_QUANTITY=10

# ── Arbitrage thresholds ──────────────────────────────────────────────────────
# Only trade when (upPrice + downPrice) < this value. 0.90 = 10c minimum profit.
ARB_THRESHOLD=0.90

# Spread between strong-arb (market order) and near-threshold (limit order)
SLIPPAGE_BUFFER=0.05

# Flat slippage tolerance used as the floor for dynamic slippage estimation
MAX_SLIPPAGE=0.02

# ── Volatility filter ─────────────────────────────────────────────────────────
# Abort a trade if UP or DOWN price swings more than this over the last ~30
# seconds (60-entry history window). 0.05 = 5c max swing.
MAX_PRICE_VOLATILITY=0.05

# Minimum history entries required before the volatility/slippage filters
# activate. Prevents false positives on startup when history is thin.
MIN_HISTORY_FOR_FILTER=10

# ── Execution ─────────────────────────────────────────────────────────────────
# Hard timeout for order submission (ms). Orders exceeding this are abandoned.
EXECUTION_TIMEOUT_MS=50

# Maximum acceptable end-to-end latency (ms)
MAX_LATENCY_MS=100

# Cancel open orders this many ms before market endTime
CANCEL_BEFORE_END_TIME_MS=10000

# ── Risk controls ─────────────────────────────────────────────────────────────
MAX_POSITION_SIZE=1000
MAX_DAILY_TRADES=100

# ── Data freshness ────────────────────────────────────────────────────────────
# Mark market data as stale if no WebSocket update received within this window (ms)
MAX_DATA_AGE_MS=5000

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_RECONNECT_DELAY_MS=5000
WS_HEARTBEAT_INTERVAL_MS=30000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
# Set to 0 to disable JSON log files
ENABLE_JSON_LOGS=1
