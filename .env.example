# Arbitrage Configuration
ARB_THRESHOLD=0.9
SLIPPAGE_BUFFER=0.05
MAX_SLIPPAGE=0.02

# Execution Settings
EXECUTION_TIMEOUT_MS=50
MAX_LATENCY_MS=100

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=btc_arbitrage

# WebSocket settings
WS_RECONNECT_DELAY_MS=5000
WS_HEARTBEAT_INTERVAL_MS=30000

# Risk controls
MAX_POSITION_SIZE=1000
MAX_DAILY_TRADES=100

# Logging
LOG_DIR=./logs
ENABLE_JSON_LOGS=1
LOG_LEVEL=info

# Trading
ENABLE_TRADING=0
DEFAULT_QUANTITY=10

# Data freshness
MAX_DATA_AGE_MS=5000
CANCEL_BEFORE_END_TIME_MS=10000

# Polymarket Exchange (CTF Exchange contract address)
POLYMARKET_EXCHANGE_ADDRESS=

# Polymarket Wallet Configuration (REQUIRED for trading)
# Wallet types: main = EOA (MetaMask), proxy = Polymarket profile wallet
POLY_PRIVATE_KEY=your_private_key_hex
POLY_WALLET_TYPE=main
# POLY_FUNDER=0x...  # Required if using proxy wallet
POLY_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Polymarket WebSocket URL
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
